var assert_counter = require("assert_counter.ltn")
var assert = assert_counter.assert
var assert_not = assert_counter.assert_not
// Testing Global Lock
var global_lock_test_counter = 5
{
	var n = 1000
	function increment_global_counter(value)
	{
		global_lock_test_counter += value;
	}
	write("");
	tasks(n, increment_global_counter, 1)
	assert(global_lock_test_counter, n + 5, "Failed Global Lock Test 1.")
}
{
	// Testing UpValue Lock
	var n = 1000
	var this_list = ListInit(n, "not_used_value")
	var upvalue_lock_test_counter = 5
	function many(item, index)
	{
		upvalue_lock_test_counter++;
	}
	this_list:rmap(n, many)
	assert(upvalue_lock_test_counter, n + 5, "Failed UpValue Lock Test 1.")
}
{
	// False contention test (BUG: performance, not correctness)
	// All Float/Integer/Bool globals share TypeUnit.Float/Integer/Boolean as their lock object.
	// This means parallel tasks updating DIFFERENT globals of the same type serialize
	// unnecessarily. After the fix (per-slot lock array), they will run independently.
	//
	// Correctness: independent parallel updates to two separate global counters must
	// both reach the right totals. This test will PASS both before and after the fix.
	// Performance improvement can only be validated by timing, not assertion.
	var counter_a = 0
	var counter_b = 0
	var n = 500
	function inc_a(value) { counter_a += value }
	function inc_b(value) { counter_b += value }
	tasks(n, inc_a, 1)
	tasks(n, inc_b, 1)
	assert(counter_a, n, "Failed false contention test A (counter_a wrong).")
	assert(counter_b, n, "Failed false contention test B (counter_b wrong).")
	// After per-slot lock fix: counter_a and counter_b should use independent locks,
	// so tasks(n, inc_a) and tasks(n, inc_b) running concurrently won't serialize.
}
return assert_counter.get_error_counter()