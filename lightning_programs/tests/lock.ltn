var assert_counter = require("assert_counter.ltn")
var assert = assert_counter.assert
var assert_not = assert_counter.assert_not
// Testing Global Lock
var global_lock_test_counter = 5
{
	var n = 1000
	function increment_global_counter(value)
	{
		global_lock_test_counter += value;
	}
	write("");
	tasks(n, increment_global_counter, 1)
	assert(global_lock_test_counter, n + 5, "Failed Global Lock Test 1.")
}
{
	// Testing UpValue Lock
	var n = 1000
	var this_list = list_init(n, "not_used_value")
	var upvalue_lock_test_counter = 5
	function many(item, index)
	{
		upvalue_lock_test_counter++;
	}
	this_list:rmap(n, many)
	assert(upvalue_lock_test_counter, n + 5, "Failed UpValue Lock Test 1.")
}
{
	// False contention via tasks(): two Integer globals updated by separate task batches.
	// Sequential batches, but verifies the tasks() path doesn't corrupt independent globals.
	var n = 500
	var tasks_a = 0
	var tasks_b = 0
	function inc_a(value) { tasks_a += value }
	function inc_b(value) { tasks_b += value }
	tasks(n, inc_a, 1)
	tasks(n, inc_b, 1)
	assert(tasks_a, n, "Failed false contention tasks() test: tasks_a.")
	assert(tasks_b, n, "Failed false contention tasks() test: tasks_b.")
}
{
	// False contention via pmap(): two Integer globals updated concurrently from the same batch.
	// Before the per-slot lock fix both locked on TypeUnit.Integer (shared singleton),
	// so tasks for counter_a serialized against tasks for counter_b unnecessarily.
	// After the fix each slot has its own lock object; the correctness assertion
	// catches any regression that breaks isolation.
	var n = 1000
	var list = list_init(n, 0)
	var counter_a = 0
	var counter_b = 0
	function split_int(item, index)
	{
		if (index < 500)
			counter_a += 1
		else
			counter_b += 1
		return item
	}
	list:pmap(split_int)
	assert(counter_a, 500, "Failed false contention pmap() test: counter_a (Integer).")
	assert(counter_b, 500, "Failed false contention pmap() test: counter_b (Integer).")
}
{
	// False contention via pmap(): Integer and Float globals updated concurrently.
	var n = 1000
	var list = list_init(n, 0)
	var int_count = 0
	var float_count = 0.0
	function split_mixed(item, index)
	{
		if (index < 500)
			int_count += 1
		else
			float_count += 1.0
		return item
	}
	list:pmap(split_mixed)
	assert(int_count, 500, "Failed false contention pmap() test: int_count.")
	assert(float_count, 500.0, "Failed false contention pmap() test: float_count.")
}
return assert_counter.get_error_counter()