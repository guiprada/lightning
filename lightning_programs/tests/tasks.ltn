var assert_counter = require("assert_counter.ltn")
var assert = assert_counter.assert
var assert_not = assert_counter.assert_not

{
	// Scalar args: all tasks receive same value type, result table has n slots
	var n = 5
	function double(args) { return args * 2 }
	var result = tasks(n, double, 3)
	assert(result:count(), n, "tasks() scalar: result size should be n.")
	for (var i = 0; i < n; i++)
	{
		assert(result[i], 6, "tasks() scalar: slot " .. i .. " should be 6.")
	}
}

{
	// Table args: tasks read fields from shared table, return computed values
	var n = 10
	var args = Table()
	args.x = 7
	function read_x(args) { return args.x * 2 }
	var result = tasks(n, read_x, args)
	assert(result:count(), n, "tasks() table args: result size should be n.")
	for (var i = 0; i < n; i++)
	{
		assert(result[i], 14, "tasks() table args: slot " .. i .. " should be 14.")
	}
}

{
	// n=0 edge case: zero tasks, empty result table
	function noop(args) { return 1 }
	var result = tasks(0, noop, 0)
	assert(result:count(), 0, "tasks() n=0: result should be empty.")
}

{
	// n=1 edge case: single task, single element result table
	function identity(args) { return args }
	var result = tasks(1, identity, 42)
	assert(result:count(), 1, "tasks() n=1: result size should be 1.")
	assert(result[0], 42, "tasks() n=1: slot 0 should be 42.")
}

{
	// func returns null: result table has n null slots (option A — size is always n)
	var n = 4
	function returns_null(args) { return null }
	var result = tasks(n, returns_null, 0)
	assert(result:count(), n, "tasks() null return: result size should be n.")
	for (var i = 0; i < n; i++)
	{
		assert(is_null(result[i]), true, "tasks() null return: slot " .. i .. " should be null.")
	}
}

{
	// const: mutation attempt on const table args must throw, args must be unchanged
	var args = Table()
	args.x = 1
	function try_mutate(args)
	{
		args.x = 2
		return args.x
	}
	var threw = try(\{ tasks(1, try_mutate, args) }, [])
	assert(threw:is_error(), true, "tasks() const: mutation of args should throw.")
	assert(args.x, 1, "tasks() const: args must be unchanged after attempted mutation.")
}

{
	// const: nested tasks() with same args is allowed — args is already const, propagates
	var args = Table()
	args.x = 1
	function inner(args) { return args.x }
	function outer(args)
	{
		return tasks(2, inner, args)
	}
	var result = tasks(2, outer, args)
	assert(result:count(), 2, "tasks() nested: result size should be 2.")
}

{
	// const: reading const table args is allowed
	var args = Table()
	args.value = 99
	function read_only(args) { return args.value }
	var result = tasks(3, read_only, args)
	assert(result:count(), 3, "tasks() const read: result size should be 3.")
	for (var i = 0; i < 3; i++)
	{
		assert(result[i], 99, "tasks() const read: slot " .. i .. " should be 99.")
	}
}

{
	// Scalar args are value types — always safe
	var result = tasks(4, function(args) { return args + 1 }, 10)
	assert(result:count(), 4, "tasks() scalar: result size should be 4.")
	for (var i = 0; i < 4; i++)
	{
		assert(result[i], 11, "tasks() scalar: slot " .. i .. " should be 11.")
	}
}

{
	// Large n: result table has exactly n slots, boundary slots correct
	var n = 1000
	function constant(args) { return args }
	var result = tasks(n, constant, 99)
	assert(result:count(), n, "tasks() large n: result size should be n.")
	assert(result[0], 99, "tasks() large n: first slot should be 99.")
	assert(result[n - 1], 99, "tasks() large n: last slot should be 99.")
}

{
	// const: table remains mutable in outer scope after tasks() returns
	// tasks() stamps PROTECTION_CONST only on the local copy it distributes
	var args = Table()
	args.x = 1
	function read_x(args) { return args.x }
	tasks(3, read_x, args)
	args.x = 42
	assert(args.x, 42, "tasks() post: table must be mutable after tasks() returns.")
}

{
	// const: const flag on args does not bleed onto unrelated tables
	var side = Table()
	side.x = 0
	var args = Table()
	args.x = 7
	function read_args(args) { return args.x }
	var result = tasks(3, read_args, args)
	assert(result:count(), 3, "tasks() const scope: result size should be 3.")
	assert(result[0], 7, "tasks() const scope: slot 0 should be 7.")
	side.x = 99
	assert(side.x, 99, "tasks() const scope: unrelated table must remain mutable.")
}

{
	// const() intrinsic: creates a const alias — mutation throws, original unchanged
	var t = Table()
	t.x = 1
	var ct = const(t)
	var threw = try(\{ ct.x = 2 }, [])
	assert(threw:is_error(), true, "const(): mutation through const alias should throw.")
	assert(t.x, 1, "const(): original table must be unchanged.")
	t.x = 42
	assert(t.x, 42, "const(): original table must remain mutable.")
}

return assert_counter.get_error_counter()
