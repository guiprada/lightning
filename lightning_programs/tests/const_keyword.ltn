var assert_counter = require("assert_counter.ltn")
var assert = assert_counter.assert

{
	// var const: scalar — now succeeds (TypeUnit singleton carries PROTECTION_CONST)
	var const x = 5
	assert(x, 5, "var const scalar: value must be readable.")
}

{
	// var const: scalar — rebinding must throw (ASSIGN_VARIABLE const check)
	var const x = 5
	var threw = try(\{ x = 6 }, [])
	assert(threw:is_error(), true, "var const scalar: rebinding must throw.")
}

{
	// var const: table — heap unit gets PROTECTION_CONST, mutation must throw
	var const t = Table()
	var threw = try(\{ t.x = 1 }, [])
	assert(threw:is_error(), true, "var const table: mutation must throw.")
}

{
	// var const: table — reading fields is allowed
	var t = Table()
	t.x = 99
	var const ct = t
	assert(ct.x, 99, "var const table: reading field must work.")
}

{
	// var const: creates a const alias — original table remains mutable
	var t = Table()
	t.x = 1
	var const ct = t
	var threw = try(\{ ct.x = 2 }, [])
	assert(threw:is_error(), true, "var const alias: mutation through const alias must throw.")
	t.x = 42
	assert(t.x, 42, "var const alias: original table must remain mutable.")
}

{
	// deep const: GET propagates PROTECTION_CONST through field chains
	var inner = Table()
	inner.y = 7
	var outer = Table()
	outer.inner = inner
	var const co = outer
	var sub = co.inner  // sub must inherit const protection
	var threw = try(\{ sub.y = 99 }, [])
	assert(threw:is_error(), true, "deep const: field access from const must return const.")
}

{
	// function param: default (no annotation) — implicitly const, scalar succeeds
	function f(n) { return n + 1 }
	assert(f(10), 11, "default param scalar: call with scalar must succeed.")
}

{
	// function param: default (no annotation) — heap arg gets PROTECTION_CONST applied, call succeeds
	function f(t) { return t.x }
	var t = Table()
	t.x = 5
	assert(f(t), 5, "default param table: call with table must succeed.")
}

{
	// function param: default — mutation of implicitly-const param must throw
	function f(t) { t.x = 99 }
	var t = Table()
	t.x = 1
	var threw = try(\{ f(t) }, [])
	assert(threw:is_error(), true, "default param: mutation of implicit const param must throw.")
	assert(t.x, 1, "default param: original table must be unchanged after failed mutation.")
}

{
	// function param: mut — mutable shared reference
	function f(mut t) { t.x = 99 }
	var t = Table()
	t.x = 1
	f(t)
	assert(t.x, 99, "mut param: mutation visible through shared reference.")
}

{
	// function param: scalar — value type, always copied
	function f(n) { return n + 1 }
	assert(f(10), 11, "scalar param: call with scalar must succeed.")
}

{
	// & move: var x = &y tombstones y, x is mutable
	var a = Table()
	a.x = 1
	var b = &a
	b.x = 99
	assert(b.x, 99, "& move declaration: moved var is mutable.")
	var threw = try(\{ var _ = a.x }, [])
	assert(threw:is_error(), true, "& move declaration: tombstoned var access must throw.")
}

{
	// & move: assignment x = &y tombstones y
	var a = Table()
	a.x = 1
	var b = Table()
	b.x = 0
	b = &a
	b.x = 99
	assert(b.x, 99, "& move assignment: moved var is mutable.")
}

return assert_counter.get_error_counter()
