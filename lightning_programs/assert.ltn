var lib = Table()

lib.assert = function(value1, value2, msg)
{
	if(value1 != value2){
		write_line(msg .. " | expected: " .. value2 .. " got: " .. value1)
		return false
	}
	return true
}
lib.assert_not = function(value1, value2, msg)
{
	if(value1 == value2){
		write_line(msg .. " | expected: not " .. value2 .. " got: " .. value1)
		return false
	}
	return true
}

return lib